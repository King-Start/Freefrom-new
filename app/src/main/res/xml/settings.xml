<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="@string/category_base"
        app:iconSpaceReserved="false">
        <SwitchPreference
            android:key="hide_from_recent"
            android:title="@string/switch_hide_recent"
            android:summary="@string/switch_hide_recent_summary"
            app:iconSpaceReserved="false"/>
        <com.sunshine.freeform.ui.view.IntegerSimpleMenuPreference
            app:entries="@array/service_type"
            app:entryValues="@array/service_type_value"
            android:key="service_type"
            android:title="@string/service_type_title"
            android:summary="@string/service_type_summary"
            app:iconSpaceReserved="false"/>
        <SwitchPreference
            android:key="use_shell_launch_fallback"
            android:title="Shell launch fallback"
            android:summary="Try an alternative shell-based method to open the app if the default launch method fails on this device"
            app:defaultValue="false"
            app:iconSpaceReserved="false"/>

        <Preference
            android:key="reset_overlay_setting"
            app:title="@string/preference_reset_overlay_setting"
            android:summary="@string/preference_reset_overlay_setting_summary"
            app:iconSpaceReserved="false"/>
        <Preference
            android:title="@string/preference_start_by_recent_view_title"
            android:summary="@string/preference_start_by_recent_view_summary"
            app:iconSpaceReserved="false"/>
    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/category_freeform"
        app:iconSpaceReserved="false">

        <SeekBarPreference
            android:key="freeform_scale"
            android:title="@string/setting_freeform_dpi_title"
            app:iconSpaceReserved="false"
            app:defaultValue="50"
            app:min="50"
            android:max="500"
            app:showSeekBarValue="true"/>

        <SeekBarPreference
            android:key="freeform_size"
            android:title="Freeform size"
            app:iconSpaceReserved="false"
            app:defaultValue="75"
            app:min="10"
            android:max="100"
            app:showSeekBarValue="true"/>

        <SeekBarPreference
            android:key="freeform_size_land"
            android:title="Freeform size landscape"
            app:iconSpaceReserved="false"
            app:defaultValue="90"
            app:min="10"
            android:max="100"
            app:showSeekBarValue="true"/>

        <SeekBarPreference
            android:key="freeform_float_view_size"
            android:title="Freeform float window Size"
            app:iconSpaceReserved="false"
            app:defaultValue="20"
            app:min="10"
            android:max="50"
            app:showSeekBarValue="true"/>

        <SeekBarPreference
            android:key="freeform_dimming_amount"
            android:title="Freeform dimming amount"
            app:iconSpaceReserved="false"
            app:defaultValue="20"
            app:min="0"
            android:max="100"
            app:showSeekBarValue="true"/>

        <SeekBarPreference
            android:key="max_freeform_windows"
            android:title="Max floating windows"
            android:summary="Maximum number of active floating windows"
            app:iconSpaceReserved="false"
            app:defaultValue="5"
            app:min="1"
            android:max="10"
            app:showSeekBarValue="true"/>

        <SwitchPreference
            android:key="remember_freeform_position"
            android:title="@string/remember_position_title"
            android:summary="@string/remember_position_summary"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="remember_freeform_size"
            android:title="Remember freeform size"
            android:summary="Remember the last size of floating window"
            app:defaultValue="true"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="use_sui_refuse_to_fullscreen"
            android:title="@string/use_sui_refuse_to_fullscreen_title"
            android:summary="@string/use_sui_refuse_to_fullscreen_summary"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="manual_adjust_freeform_rotation"
            android:title="@string/manual_adjust_freeform_rotation_title"
            android:summary="@string/manual_adjust_freeform_rotation_summary"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="enable_suspend_mode"
            android:title="Suspend mode"
            android:summary="Double tap bottom bar to minimize window to corner"
            app:defaultValue="true"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="enable_destroy_anim"
            android:title="Close animation"
            android:summary="Fade out animation when closing floating window"
            app:defaultValue="true"
            app:iconSpaceReserved="false"/>

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Gesture"
        app:iconSpaceReserved="false">

        <SwitchPreference
            android:key="enable_swipe_back"
            android:title="Swipe back gesture"
            android:summary="Swipe from left edge to trigger back button"
            app:defaultValue="true"
            app:iconSpaceReserved="false"/>

        <SeekBarPreference
            android:key="swipe_back_indicator_alpha"
            android:title="Swipe back indicator opacity"
            android:summary="Opacity of swipe back indicator bar"
            app:iconSpaceReserved="false"
            app:defaultValue="80"
            app:min="0"
            android:max="100"
            app:showSeekBarValue="true"/>

        <SwitchPreference
            android:key="enable_swipe_home"
            android:title="Swipe up = Home"
            android:summary="Swipe up from bottom edge to go home"
            app:defaultValue="false"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="enable_swipe_forward"
            android:title="Swipe left = Forward"
            android:summary="Swipe from right edge to go forward"
            app:defaultValue="false"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="enable_pinch_resize"
            android:title="Pinch to resize"
            android:summary="Use two fingers to resize floating window"
            app:defaultValue="false"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="enable_shake_minimize"
            android:title="Shake to minimize"
            android:summary="Shake device to minimize floating window"
            app:defaultValue="false"
            app:iconSpaceReserved="false"/>

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Appearance"
        app:iconSpaceReserved="false">

        <SeekBarPreference
            android:key="window_opacity"
            android:title="Window opacity"
            android:summary="Transparency of floating window"
            app:iconSpaceReserved="false"
            app:defaultValue="100"
            app:min="20"
            android:max="100"
            app:showSeekBarValue="true"/>

        <SeekBarPreference
            android:key="corner_radius"
            android:title="Corner radius"
            android:summary="Rounded corner size of floating window"
            app:iconSpaceReserved="false"
            app:defaultValue="0"
            app:min="0"
            android:max="50"
            app:showSeekBarValue="true"/>

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Performance"
        app:iconSpaceReserved="false">

        <SwitchPreference
            android:key="auto_close_screen_off"
            android:title="Auto close on screen off"
            android:summary="Close all floating windows when screen turns off"
            app:defaultValue="false"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="auto_minimize_on_call"
            android:title="Auto minimize on call"
            android:summary="Minimize floating window when phone call comes in"
            app:defaultValue="false"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="lock_window_position"
            android:title="Lock window position"
            android:summary="Prevent floating window from being moved"
            app:defaultValue="false"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="tap_outside_to_close"
            android:title="Tap outside to close"
            android:summary="Tap outside floating window to close it. Turn off to prevent accidental close"
            app:defaultValue="false"
            app:iconSpaceReserved="false"/>

        <Preference
            android:key="battery_optimization_exemption"
            android:title="Ignore battery optimization"
            android:summary="Exempt this app so Android doesn't kill the background service"
            app:iconSpaceReserved="false"/>

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Utilities"
        app:iconSpaceReserved="false">

        <SwitchPreference
            android:key="snap_to_edge"
            android:title="Snap to edge"
            android:summary="Window automatically snaps to screen edge when released"
            app:defaultValue="true"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="enable_quick_notes"
            android:title="Quick notes"
            android:summary="Show a sticky note beside floating window"
            app:defaultValue="false"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="enable_focus_timer"
            android:title="Focus timer (Pomodoro)"
            android:summary="25 minute focus timer above floating window. Tap to start/stop"
            app:defaultValue="false"
            app:iconSpaceReserved="false"/>

        <SwitchPreference
            android:key="show_perf_overlay"
            android:title="Performance overlay"
            android:summary="Show RAM usage on floating window"
            app:defaultValue="false"
            app:iconSpaceReserved="false"/>

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/category_floating"
        app:iconSpaceReserved="false">

        <SwitchPreference
            android:key="show_floating"
            android:title="@string/switch_floating"
            android:summary="@string/switch_floating_summary"
            app:iconSpaceReserved="false"/>

        <com.sunshine.freeform.ui.view.IntegerSimpleMenuPreference
            app:entries="@array/floating_show_position"
            app:entryValues="@array/floating_show_position_value"
            android:key="floating_position_x"
            android:title="@string/menu_floating_position"
            app:iconSpaceReserved="false"/>

        <Preference
            android:key="quick_floating_app"
            app:title="@string/preference_quick_floating_app"
            android:summary="@string/preference_quick_floating_app_summary"
            app:iconSpaceReserved="false"/>

        <SeekBarPreference
            android:key="floating_alpha"
            android:title="@string/floating_alpha_title"
            app:iconSpaceReserved="false"
            app:defaultValue="10"
            app:min="0"
            android:max="10"
            app:showSeekBarValue="true"/>

        <SwitchPreference
            android:key="floating_show_location"
            android:title="Show coordinates while dragging"
            android:summary="Display the floating button's Y position on screen while you drag it"
            app:defaultValue="false"
            app:iconSpaceReserved="false"/>

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/category_notify"
        app:iconSpaceReserved="false">

        <SwitchPreference
            android:key="notify_freeform"
            android:title="@string/switch_notify_freeform"
            android:summary="@string/switch_notify_freeform_summary"
            app:iconSpaceReserved="false"/>

        <Preference
            android:key="notification_freeform_apps"
            app:title="@string/preference_notification_apps"
            android:summary="@string/preference_notification_apps_summary"
            app:iconSpaceReserved="false"/>

    </PreferenceCategory>

</PreferenceScreen>
